# RAG Doküman Soru-Cevap Sistemi - Konfigürasyon

# ============================================
# AŞAMA 1: Lokal RAG (Temel Konfigürasyon)
# ============================================

# PDF İşleme
CHUNK_SIZE=500
CHUNK_OVERLAP=100

# Embedding Modeli
EMBEDDING_MODEL=sentence-transformers/all-MiniLM-L6-v2
EMBEDDING_DIM=385

# Arama Parametreleri
TOP_K_SEARCH=3

# ============================================
# AŞAMA 2: AWS Entegrasyonu
# ============================================

# AWS Kimlik Doğrulaması
AWS_REGION=eu-west-1
AWS_ACCESS_KEY_ID=your_access_key
AWS_SECRET_ACCESS_KEY=your_secret_key

# S3 Ayarları
AWS_S3_BUCKET_NAME=rag-documents-bucket
AWS_S3_PREFIX=documents/

# Bedrock LLM Ayarları
BEDROCK_MODEL_ID=anthropic.claude-v2
BEDROCK_MAX_TOKENS=500
BEDROCK_TEMPERATURE=0.7

# OpenSearch Ayarları
OPENSEARCH_ENDPOINT=your-domain.eu-west-1.aes.amazonaws.com
OPENSEARCH_INDEX_NAME=rag_documents
OPENSEARCH_VECTOR_SIZE=385

# ============================================
# AŞAMA 3: LLM Seçimi
# ============================================

# OpenAI API (Eğer OpenAI kullanmak istiyorsanız)
OPENAI_API_KEY=sk-...
OPENAI_MODEL=gpt-3.5-turbo

# ============================================
# Streamlit Ayarları
# ============================================

STREAMLIT_SERVER_HEADLESS=true
STREAMLIT_SERVER_PORT=8503
STREAMLIT_SERVER_ADDRESS=0.0.0.0

# ============================================
# Logging
# ============================================

LOG_LEVEL=INFO
LOG_FILE=logs/rag_system.log
